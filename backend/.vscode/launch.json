      "webRoot": "C:\\Users\\amcen\\OneDrive\\Desktop\\AMCENXDOSTWEBSITE",
      "userDataDir": "C:\\Users\\amcen\\OneDrive\\Desktop\\AMCENXDOSTWEBSITE\\.vscode\\chrome-debug",
      "runtimeArgs": ["--remote-debugging-port=9222", "--no-first-run", "--no-default-browser-check"],
      "sourceMapPathOverrides": {
        "webpack:///./~/*": "${webRoot}/node_modules/*",
        "webpack:///../*": "${webRoot}",
        "webpack:///src/*": "${webRoot}/src/*"
