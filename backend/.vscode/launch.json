{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "pwa-msedge",
      "request": "launch",
      "name": "Launch Edge",
      "url": "file:///C:/Users/amcen/OneDrive/Desktop/AMCENXDOSTWEBSITE/Main%20page%20pc.html",
      "webRoot": "${workspaceFolder}",
      "runtimeArgs": ["--no-first-run", "--no-default-browser-check"],
